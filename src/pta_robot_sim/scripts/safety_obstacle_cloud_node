#!/usr/bin/env python3

import math

import rclpy
from rclpy.node import Node
from rclpy.qos import qos_profile_sensor_data

from sensor_msgs.msg import LaserScan, PointCloud2
from std_msgs.msg import Header
import sensor_msgs_py.point_cloud2 as pc2


class SafetyObstacleCloudNode(Node):
    def __init__(self):
        super().__init__("safety_obstacle_cloud_node")

        # Do NOT declare use_sim_time here.
        # ROS 2 declares/sets it automatically when passed from launch.
        self.declare_parameter("input_scan_topic", "/scan")
        self.declare_parameter("output_cloud_topic", "/safety_obstacle_cloud")
        self.declare_parameter("padding_radius", 0.22)
        self.declare_parameter("point_z", 0.05)
        self.declare_parameter("points_per_hit", 12)
        self.declare_parameter("scan_stride", 2)

        input_scan_topic = self.get_parameter("input_scan_topic").value
        output_cloud_topic = self.get_parameter("output_cloud_topic").value

        self.padding_radius = float(self.get_parameter("padding_radius").value)
        self.point_z = float(self.get_parameter("point_z").value)
        self.points_per_hit = int(self.get_parameter("points_per_hit").value)
        self.scan_stride = int(self.get_parameter("scan_stride").value)

        self.pub = self.create_publisher(
            PointCloud2,
            output_cloud_topic,
            10,
        )

        self.sub = self.create_subscription(
            LaserScan,
            input_scan_topic,
            self.scan_callback,
            qos_profile_sensor_data,
        )

        self.get_logger().info(
            f"Publishing safety obstacle cloud: {input_scan_topic} -> {output_cloud_topic}, "
            f"padding_radius={self.padding_radius}, "
            f"points_per_hit={self.points_per_hit}, "
            f"scan_stride={self.scan_stride}"
        )

    def scan_callback(self, msg: LaserScan):
        points = []

        stride = max(1, self.scan_stride)
        ring_count = max(4, self.points_per_hit)

        for i in range(0, len(msg.ranges), stride):
            r = msg.ranges[i]

            if not math.isfinite(r):
                continue

            if r < msg.range_min or r > msg.range_max:
                continue

            angle = msg.angle_min + i * msg.angle_increment

            x = r * math.cos(angle)
            y = r * math.sin(angle)

            # Original obstacle point
            points.append((x, y, self.point_z))

            # Virtual padding ring around every obstacle point
            for k in range(ring_count):
                theta = 2.0 * math.pi * float(k) / float(ring_count)
                px = x + self.padding_radius * math.cos(theta)
                py = y + self.padding_radius * math.sin(theta)
                points.append((px, py, self.point_z))

        # Important:
        # Use current node time, not msg.header.stamp.
        # This prevents TF "timestamp earlier than transform cache" drops.
        header = Header()
        header.stamp = self.get_clock().now().to_msg()
        header.frame_id = msg.header.frame_id

        cloud = pc2.create_cloud_xyz32(header, points)
        self.pub.publish(cloud)


def main(args=None):
    rclpy.init(args=args)
    node = SafetyObstacleCloudNode()

    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == "__main__":
    main()
